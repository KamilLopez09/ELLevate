NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Telemetry writes go through the camper-telemetry Edge Function (service role,
# injected by Supabase — not set here). Organizer /admin reads use the
# organizer-telemetry function; set ORGANIZER_PASSWORD in Supabase Edge Function
# secrets (not in this file). Deploy both: npm run supabase:deploy-organizer

# Optional: Cursor MCP integrations (set in shell profile or ~/.cursor/.env — do not commit secrets)
# MAGIC_API_KEY=           # 21st.dev Magic MCP — https://21st.dev/magic/console
# SUPABASE_ACCESS_TOKEN= # Supabase MCP — https://supabase.com/dashboard/account/tokens
